From 170a85e55a5ca264703ad9c9ed123774321a4fb9 Mon Sep 17 00:00:00 2001
From: j <dirkmcpherson@gmail.com>
Date: Thu, 23 Jul 2026 23:53:30 -0400
Subject: [PATCH 2/2] per-env camera poses for ENV_SEPARATE batched renders

A camera node may carry env_poses (N,4,4) world transforms; env i's render pass then
uses pose i for the view matrix (and derives cam_pos from it). Enables ONE batched
render call to serve N differently-posed cameras -- e.g. wrist-mounted cams in
scene.build(n_envs=N) scenes, where Camera.attach raises and N serial set_pose+render
calls scale quadratically. No-op unless env_poses is set (validated bit-identical to
the serial ground truth; 227x faster at N=8).

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01AVJaT7Q3CMdpEUB5ogc3GM
---
 genesis/ext/pyrender/renderer.py | 23 +++++++++++++++--------
 1 file changed, 15 insertions(+), 8 deletions(-)
 mode change 100644 => 100755 genesis/ext/pyrender/renderer.py

diff --git a/genesis/ext/pyrender/renderer.py b/genesis/ext/pyrender/renderer.py
old mode 100644
new mode 100755
index 63d2a11..d1e4e43
--- a/genesis/ext/pyrender/renderer.py
+++ b/genesis/ext/pyrender/renderer.py
@@ -437,9 +437,8 @@ class Renderer(object):
         glClearColor(0.0, 0.0, 0.0, 1.0)
         glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)
 
-        V, P = self._get_camera_matrices(scene)
-
-        cam_pos = scene.get_pose(scene.main_camera_node)[:3, 3]
+        V, P = self._get_camera_matrices(scene, env_idx)
+        cam_pos = np.linalg.inv(V)[:3, 3]
         screen_size = np.array([self.viewport_width, self.viewport_height], np.float32)
 
         self.jit.forward_pass(
@@ -474,8 +473,8 @@ class Renderer(object):
             glDisable(GL_MULTISAMPLE)
 
         # Set up camera matrices
-        V, P = self._get_camera_matrices(scene)
-        cam_pos = scene.get_pose(scene.main_camera_node)[:3, 3]
+        V, P = self._get_camera_matrices(scene, env_idx)
+        cam_pos = np.linalg.inv(V)[:3, 3]
 
         floor_tex = self._floor_texture_color._texid if flags & RenderFlags.REFLECTIVE_FLOOR else 0
         screen_size = np.array([self.viewport_width, self.viewport_height], np.float32)
@@ -545,7 +544,7 @@ class Renderer(object):
         program = None
 
         # Set up camera matrices
-        V, P = self._get_camera_matrices(scene)
+        V, P = self._get_camera_matrices(scene, env_idx)
 
         # Now, render each object in sorted order
         for node in scene.sorted_mesh_nodes():
@@ -857,12 +856,20 @@ class Renderer(object):
     # Camera Matrix Management
     ###########################################################################
 
-    def _get_camera_matrices(self, scene):
+    def _get_camera_matrices(self, scene, env_idx=-1):
         main_camera_node = scene.main_camera_node
         if main_camera_node is None:
             raise ValueError("Cannot render scene without a camera")
         P = main_camera_node.camera.get_projection_matrix(width=self.viewport_width, height=self.viewport_height)
         pose = scene.get_pose(main_camera_node)
+        # genesis_pickaplace patch: per-env camera poses. A camera node may carry
+        # `env_poses` (N,4,4) world transforms; in an ENV_SEPARATE batched render,
+        # env i's pass then views from pose i. This makes ONE batched render call
+        # serve N differently-posed (e.g. wrist-mounted) cameras -- Camera.attach
+        # is unsupported for n_envs>0, and N separate calls scale quadratically.
+        env_poses = getattr(main_camera_node, "env_poses", None)
+        if env_poses is not None and env_idx >= 0:
+            pose = np.asarray(env_poses[env_idx], dtype=np.float64)
         V = np.linalg.inv(pose)  # V maps from world to camera
         return V, P
 
@@ -1242,7 +1249,7 @@ class Renderer(object):
 
     def _forward_pass_no_reset(self, scene, flags, env_idx=-1):
         # Set up camera matrices
-        V, P = self._get_camera_matrices(scene)
+        V, P = self._get_camera_matrices(scene, env_idx)
 
         # Now, render each object in sorted order
         for node in scene.sorted_mesh_nodes():
